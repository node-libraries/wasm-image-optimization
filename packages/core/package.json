{
  "name": "wasm-image-optimization",
  "version": "2.0.8",
  "description": "Optimize images with wasm on edge runtime",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "wasm-image-optimization": "./dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b && rolldown -c rolldown.config.js"
  },
  "exports": {
    ".": {
      "workerd": {
        "types": "./dist/workerd.d.ts",
        "import": "./dist/workerd.js"
      },
      "deno": {
        "types": "./dist/single.d.ts",
        "import": "./dist/single.js"
      },
      "single": {
        "types": "./dist/single.d.ts",
        "import": "./dist/single.js"
      },
      "types": "./dist/single.d.ts",
      "import": "./dist/single.js",
      "default": "./dist/single.js"
    },
    "./workerd": {
      "types": "./dist/workerd.d.ts",
      "import": "./dist/workerd.js"
    },
    "./workers": {
      "types": "./dist/workers.d.ts",
      "workerd": "./dist/dummy.js",
      "node": "./dist/workers.js",
      "browser": "./dist/workers.js",
      "default": "./dist/dummy.js"
    },
    "./single": {
      "types": "./dist/single.d.ts",
      "import": "./dist/single.js"
    },
    "./wasm-image-optimization.js": "./dist/wasm-image-optimization.js",
    "./wasm-image-optimization.wasm": "./dist/wasm-image-optimization.wasm",
    "./vite-plugin": {
      "types": "./dist/vite-plugin.d.ts",
      "default": "./dist/vite-plugin.js"
    }
  },
  "typesVersions": {
    "*": {
      "workers": [
        "./dist/workers.d.ts"
      ],
      "workerd": [
        "./dist/workerd.d.ts"
      ],
      "single": [
        "./dist/single.d.ts"
      ],
      "*": [
        "./dist/single.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "author": "SoraKumo <info@croud.jp>",
  "license": "MIT",
  "keywords": [
    "image",
    "converter",
    "webp",
    "png",
    "jpeg",
    "avif",
    "wasm",
    "skia",
    "webassembly"
  ],
  "devDependencies": {
    "rolldown": "1.0.0-rc.7",
    "typescript": "^5.9.3",
    "vite": "7.3.1"
  },
  "dependencies": {
    "commander": "14.0.3",
    "worker-lib": "2.2.0"
  },
  "repository": "https://github.com/node-libraries/wasm-image-optimization",
  "homepage": "https://github.com/node-libraries/wasm-image-optimization/tree/master/packages/core#readme"
}
